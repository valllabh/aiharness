direction: right

user: User {
  shape: person
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
}

orchestrator: Orchestrator {
  style.fill: "#d0ebff"
  style.stroke: "#1971c2"
  style.bold: true
}

test-runner: Test\nRunner {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

scoring-engine: Scoring\nEngine {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

deployment-gate: Deployment\nGate {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

guardrails: Guardrails {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

benchmark-datasets: Benchmark\nDatasets {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

red-team-scanner: Red Team\nScanner {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

comparison-framework: Comparison\nFramework {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

cicd-gate: CI/CD\nGate {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

production-monitor: Production\nMonitor {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

response: Response {
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
  style.bold: true
}

# User to Orchestrator
user -> orchestrator

# Orchestrator to its services
orchestrator -> test-runner
orchestrator -> scoring-engine
orchestrator -> deployment-gate
orchestrator -> guardrails

# Test Runner to dependencies
test-runner -> benchmark-datasets
test-runner -> red-team-scanner

# Scoring Engine to dependencies
scoring-engine -> comparison-framework

# Deployment Gate to dependencies
deployment-gate -> cicd-gate
deployment-gate -> production-monitor

# Orchestrator to Response
orchestrator -> response
