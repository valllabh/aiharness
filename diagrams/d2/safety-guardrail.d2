direction: right

user: User {
  shape: person
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
}

input-pipeline: Input\nPipeline {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
  style.bold: true
}

llm: LLM API {
  style.fill: "#a5d8ff"
  style.stroke: "#1971c2"
  style.bold: true
}

output-pipeline: Output\nPipeline {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
  style.bold: true
}

input-interceptor: Input\nInterceptor {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

pii-redactor: PII\nRedactor {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

policy-engine: Policy\nEngine {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

output-filter: Output\nFilter {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

capability-gate: Capability\nGate {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

canary-tokens: Canary\nTokens {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

response: Response {
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
  style.bold: true
}

# Main flow
user -> input-pipeline
input-pipeline -> llm
llm -> output-pipeline
output-pipeline -> response

# Input Pipeline to dependencies
input-pipeline -> input-interceptor
input-pipeline -> pii-redactor
input-pipeline -> policy-engine

# Output Pipeline to dependencies
output-pipeline -> output-filter
output-pipeline -> capability-gate
output-pipeline -> canary-tokens
