direction: right

user: User {
  shape: person
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
}

orchestrator: Orchestrator {
  style.fill: "#d0ebff"
  style.stroke: "#1971c2"
  style.bold: true
}

planning-loop: Planning\nLoop {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

tool-caller: Tool\nCaller {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

state-mgr: State\nManager {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

guardrails: Guardrails {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

human-approval: Human\nApproval {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

multi-agent: Multi Agent\nCoordinator {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

external-apis: External\nAPIs {
  style.fill: "#a5d8ff"
  style.stroke: "#1971c2"
  style.bold: true
}

checkpoints: Checkpoints {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

observability: Observability {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

response: Response {
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
  style.bold: true
}

# User to Orchestrator
user -> orchestrator

# Orchestrator to its services
orchestrator -> planning-loop
orchestrator -> tool-caller
orchestrator -> state-mgr
orchestrator -> guardrails
orchestrator -> human-approval

# Planning Loop to dependencies
planning-loop -> multi-agent

# Tool Caller to dependencies
tool-caller -> external-apis

# State Manager to dependencies
state-mgr -> checkpoints
state-mgr -> observability

# Orchestrator to Response
orchestrator -> response
