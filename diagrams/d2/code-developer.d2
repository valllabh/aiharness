direction: right

user: User {
  shape: person
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
}

orchestrator: Orchestrator {
  style.fill: "#d0ebff"
  style.stroke: "#1971c2"
  style.bold: true
}

context-mgr: Context\nManager {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

model-router: Model\nRouter {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

code-executor: Code\nExecutor {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

guardrails: Guardrails {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

ast-parser: AST\nParser {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

codebase-index: Codebase\nIndex {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

lsp-integration: LSP\nIntegration {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

execution-env: Execution\nEnvironment {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

security-sandbox: Security\nSandbox {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

llm: LLM API {
  style.fill: "#a5d8ff"
  style.stroke: "#1971c2"
  style.bold: true
}

response: Response {
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
  style.bold: true
}

# User to Orchestrator
user -> orchestrator

# Orchestrator to its services
orchestrator -> context-mgr
orchestrator -> model-router
orchestrator -> code-executor
orchestrator -> guardrails

# Context Manager to dependencies
context-mgr -> ast-parser
context-mgr -> codebase-index
context-mgr -> lsp-integration

# Code Executor to dependencies
code-executor -> execution-env
code-executor -> security-sandbox

# Model Router to LLM
model-router -> llm

# Orchestrator to Response
orchestrator -> response
