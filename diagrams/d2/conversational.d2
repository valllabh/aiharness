direction: right

user: User {
  shape: person
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
}

orchestrator: Orchestrator {
  style.fill: "#d0ebff"
  style.stroke: "#1971c2"
  style.bold: true
}

context-mgr: Context\nManager {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

model-router: Model\nRouter {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

tool-executor: Tool\nExecutor {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

guardrails: Guardrails {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

system-prompt: System\nPrompt {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

conv-history: Conversation\nHistory {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

user-memory: User\nMemory {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

llm: LLM API {
  style.fill: "#a5d8ff"
  style.stroke: "#1971c2"
  style.bold: true
}

sandbox: Sandbox {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

response: Response {
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
  style.bold: true
}


# User to Orchestrator
user -> orchestrator

# Orchestrator to its services
orchestrator -> context-mgr
orchestrator -> model-router
orchestrator -> tool-executor
orchestrator -> guardrails

# Context Manager to stores
context-mgr -> system-prompt
context-mgr -> conv-history
context-mgr -> user-memory

# Model Router to LLM
model-router -> llm

# Tool Executor to Sandbox
tool-executor -> sandbox

# Orchestrator to Response
orchestrator -> response

