direction: right

user: User {
  shape: person
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
}

orchestrator: Orchestrator {
  style.fill: "#d0ebff"
  style.stroke: "#1971c2"
  style.bold: true
}

content-pipeline: Content\nPipeline {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

model-router: Model\nRouter {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

review-workflow: Review\nWorkflow {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

guardrails: Guardrails {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

compliance-checker: Compliance\nChecker {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

brand-voice: Brand Voice\nEngine {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

template-library: Template\nLibrary {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

seo-optimizer: SEO\nOptimizer {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

llm: LLM API {
  style.fill: "#a5d8ff"
  style.stroke: "#1971c2"
  style.bold: true
}

distribution-hub: Distribution\nHub {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

response: Response {
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
  style.bold: true
}

# User to Orchestrator
user -> orchestrator

# Orchestrator to its services
orchestrator -> content-pipeline
orchestrator -> model-router
orchestrator -> review-workflow
orchestrator -> guardrails
orchestrator -> compliance-checker

# Content Pipeline to components
content-pipeline -> brand-voice
content-pipeline -> template-library
content-pipeline -> seo-optimizer

# Model Router to LLM
model-router -> llm

# Review Workflow to Distribution Hub
review-workflow -> distribution-hub

# Orchestrator to Response
orchestrator -> response
