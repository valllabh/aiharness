direction: right

user: User {
  shape: person
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
}

orchestrator: Orchestrator {
  style.fill: "#d0ebff"
  style.stroke: "#1971c2"
  style.bold: true
}

retrieval-pipeline: Retrieval\nPipeline {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

model-router: Model\nRouter {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

guardrails: Guardrails {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

access-control: Access\nControl {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

document-ingestion: Document\nIngestion {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

vector-store: Vector\nStore {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

reranker: Reranker {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

chunking-engine: Chunking\nEngine {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

embedding-generator: Embedding\nGenerator {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

llm: LLM API {
  style.fill: "#a5d8ff"
  style.stroke: "#1971c2"
  style.bold: true
}

response: Response {
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
  style.bold: true
}

# User to Orchestrator
user -> orchestrator

# Orchestrator to its services
orchestrator -> retrieval-pipeline
orchestrator -> model-router
orchestrator -> guardrails
orchestrator -> access-control

# Retrieval Pipeline to dependencies
retrieval-pipeline -> document-ingestion
retrieval-pipeline -> vector-store
retrieval-pipeline -> reranker

# Document Ingestion to dependencies
document-ingestion -> chunking-engine
document-ingestion -> embedding-generator

# Model Router to LLM
model-router -> llm

# Orchestrator to Response
orchestrator -> response
