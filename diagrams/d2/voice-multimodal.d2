direction: right

user: User {
  shape: person
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
}

orchestrator: Orchestrator {
  style.fill: "#d0ebff"
  style.stroke: "#1971c2"
  style.bold: true
}

input-pipeline: Input\nPipeline {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

output-pipeline: Output\nPipeline {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

model-router: Model\nRouter {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

turn-manager: Turn\nManager {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
}

guardrails: Guardrails {
  style.fill: "#ffe3e3"
  style.stroke: "#c92a2a"
}

speech-to-text: Speech\nto Text {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

emotion-detector: Emotion\nDetector {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

multimodal-fusion: Multimodal\nFusion {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

text-to-speech: Text\nto Speech {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

streaming-engine: Streaming\nEngine {
  style.fill: "#fff9db"
  style.stroke: "#e8c400"
}

llm: LLM API {
  style.fill: "#a5d8ff"
  style.stroke: "#1971c2"
  style.bold: true
}

response: Response {
  style.fill: "#e9ecef"
  style.stroke: "#868e96"
  style.bold: true
}

# User to Orchestrator
user -> orchestrator

# Orchestrator to its services
orchestrator -> input-pipeline
orchestrator -> output-pipeline
orchestrator -> model-router
orchestrator -> turn-manager
orchestrator -> guardrails

# Input Pipeline to components
input-pipeline -> speech-to-text
input-pipeline -> emotion-detector
input-pipeline -> multimodal-fusion

# Output Pipeline to components
output-pipeline -> text-to-speech
output-pipeline -> streaming-engine

# Model Router to LLM
model-router -> llm

# Orchestrator to Response
orchestrator -> response
