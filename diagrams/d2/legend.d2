  style.font-size: 12
  width: 80
  height: 28
}
l2: Services {
  style.fill: "#d3f9d8"
  style.stroke: "#2b8a3e"
  style.font-size: 12
  width: 65
  height: 28
}
l3: Storage {
  style.fill: "#fff9db"
